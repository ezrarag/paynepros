# Postgres / Prisma
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/readyaimgo?schema=public"

# Intuit QuickBooks OAuth (sandbox first)
INTUIT_CLIENT_ID="your-intuit-client-id"
INTUIT_CLIENT_SECRET="your-intuit-client-secret"
INTUIT_REDIRECT_URI="http://localhost:3000/api/integrations/intuit/callback"
INTUIT_ENVIRONMENT="sandbox"

# Optional: app base url helper
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Client-portal fallback tenant for workspace-scoped OAuth connects
READYAIMGO_DEFAULT_TENANT_ID="paynepros"
