# Copy to .env.local and fill in real values. Never commit .env.local.

# ==============================================================================
# CLIENT-SIDE FIREBASE (PUBLIC — safe to embed in browser bundles)
# Source: Firebase Console → Project Settings → General → Your Web App
# ==============================================================================
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_APP_ID=""
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=""
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# ==============================================================================
# SERVER-SIDE FIREBASE ADMIN SDK (PRIVATE — never expose to browser)
# Source: Firebase Console → Project Settings → Service Accounts → Generate New Private Key
# admin.ts reads: FIREBASE_CLIENT_EMAIL and FIREBASE_PRIVATE_KEY (exact names required)
# ==============================================================================
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
# Paste full key from the downloaded JSON; keep literal \n escape sequences
FIREBASE_PRIVATE_KEY=""

# ==============================================================================
# AUTH (NextAuth / Auth.js)
# ==============================================================================
# Generate with: openssl rand -base64 32
AUTH_SECRET=""
# Site-wide password gate
SITE_ADMIN_PASSWORD=""
# Temp passwords for client portal dev access (comma-separated)
SITE_TEMP_PASSWORDS=""
# Generate with: openssl rand -hex 32
INTAKE_LINK_SECRET=""

# ==============================================================================
# EMAIL (Resend) — https://resend.com/api-keys
# ==============================================================================
RESEND_API_KEY=""
CLIENT_MAGIC_LINK_FROM="PaynePros <noreply@example.com>"
CONTACT_FORM_FROM="PaynePros <noreply@example.com>"

# ==============================================================================
# NOTIFICATIONS — reminder cron + Telnyx SMS
# ==============================================================================
# Generate with: openssl rand -hex 24 (set the same value in Vercel env)
CRON_SECRET=""
# Telnyx SMS — leave empty in dev (dev_log fallback active)
TELNYX_API_KEY=""
TELNYX_FROM_NUMBER=""        # E.164, from Telnyx portal after 10DLC registration
TELNYX_PUBLIC_KEY=""         # for inbound webhook signature verification

# Inbound SMS commands
ADMIN_PHONE_ALLOWLIST=""     # comma-separated E.164, e.g. "+15551234567"
ANTHROPIC_API_KEY=""         # parses inbound admin texts into structured requests

# ==============================================================================
# INTEGRATIONS
# ==============================================================================
# Intuit QuickBooks OAuth (sandbox first)
INTUIT_CLIENT_ID=""
INTUIT_CLIENT_SECRET=""
INTUIT_REDIRECT_URI="http://localhost:3000/api/integrations/intuit/callback"
INTUIT_ENVIRONMENT="sandbox"
# Google OAuth - used for the Google Workspace integration AND as a
# "Continue with Google" sign-in option on /admin/login and /client/login.
# An admin login matches the Google account email against `admin_users`;
# a client login matches it against a client workspace's primary contact email.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
SLACK_WEBHOOK_URL=""

# ==============================================================================
# PAYMENTS (Stripe) — TEST keys locally; LIVE keys only in Vercel env
# ==============================================================================
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# ==============================================================================
# DATABASE (Postgres/Prisma — QuickBooks sync only)
# ==============================================================================
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/paynepros?schema=public"

# ==============================================================================
# APP IDENTIFIERS
# ==============================================================================
READYAIMGO_DEFAULT_TENANT_ID="paynepros"
